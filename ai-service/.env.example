# AI provider keys. Leave blank to run in demo mode (rule-based replies, no external calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Fallback chain order (comma-separated). First healthy provider with a key wins.
AI_PROVIDER_PRIORITY=groq,gemini,openai

# Per-request timeout (seconds)
AI_TIMEOUT=25
