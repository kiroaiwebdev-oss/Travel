APP_NAME=TravelCash
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (matches docker-compose service "mysql") ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=travelcash
DB_USERNAME=travelcash
DB_PASSWORD=change_me_strong

# --- Redis (cache, queue, sessions, rate limiting) ---
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# --- Search (Meilisearch via Laravel Scout) ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=change_me_master_key

# --- AI sidecar (FastAPI) ---
AI_SERVICE_URL=http://ai:8001

# --- JWT (tymon/jwt-auth) ---
JWT_SECRET=
JWT_TTL=60

# --- Google OAuth (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# --- TravelCash business config ---
TC_DEFAULT_CURRENCY=INR
TC_DEFAULT_CASHBACK_PERCENT=40
TC_CASHBACK_HOLD_DAYS=30
TC_MIN_WITHDRAWAL=500
TC_AFFILIATE_COOKIE_DAYS=30
