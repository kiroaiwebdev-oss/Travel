APP_NAME=TripCash
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (matches docker-compose service "mysql") ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=travelcash
DB_USERNAME=travelcash
DB_PASSWORD=change_me_strong

# --- Redis (cache, queue, sessions, rate limiting) ---
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# --- Search (Meilisearch via Laravel Scout) ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=change_me_master_key

# --- AI sidecar (FastAPI) ---
AI_SERVICE_URL=http://ai:8001

# --- Google OAuth (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# --- TripCash business config ---
TC_DEFAULT_CURRENCY=INR
TC_DEFAULT_CASHBACK_PERCENT=40
TC_CASHBACK_HOLD_DAYS=30
TC_MIN_WITHDRAWAL=500
TC_AFFILIATE_COOKIE_DAYS=30


# --- Payout gateways (admin payouts) ---
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# --- Web Push (browser notifications) — generate with web-push VAPID ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tripcash.test


# --- Mail (SMTP) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@tripcash.test
MAIL_FROM_NAME=TripCash

# --- Twilio (SMS + WhatsApp) — or set in Admin → Integrations ---
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# --- WhatsApp Business Cloud API (Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
